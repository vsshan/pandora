# Anthropic API key — used to generate the podcast script via Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key — used for text-to-speech synthesis (tts-1, voice: nova)
OPENAI_API_KEY=your_openai_api_key_here

# Port for the Express podcast server (default: 3001)
PORT=3001

# URL of the Pometry/Raphtory Python graph service (default: http://localhost:8000)
POMETRY_URL=http://localhost:8000

# Set in Render's static site environment variables at build time:
# VITE_POMETRY_URL=https://your-pometry-service.onrender.com

# Set in Render's Python service environment variables:
# ALLOW_ORIGIN=*
